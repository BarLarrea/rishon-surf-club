<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/participants"
            android:textSize="24sp"
            android:textColor="@color/blue_primary"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_total_participants"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="16sp"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="Total Participants: 45"/>

        <!-- Categories Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_total_participants"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_max="600dp">

            <!-- Instructors -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_instructors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <include layout="@layout/item_category_header"
                    android:id="@+id/instructors_header"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Beit Halohem Tel Aviv -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_beit_halohem_ta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <include layout="@layout/item_category_header"
                    android:id="@+id/beit_halohem_ta_header"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Beit Halohem Jerusalem -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_beit_halohem_jerusalem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <include layout="@layout/item_category_header"
                    android:id="@+id/beit_halohem_jerusalem_header"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Akim -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_akim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <include layout="@layout/item_category_header"
                    android:id="@+id/akim_header"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Next Step -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_next_step"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <include layout="@layout/item_category_header"
                    android:id="@+id/next_step_header"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Volunteers -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_volunteers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <include layout="@layout/item_category_header"
                    android:id="@+id/volunteers_header"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- No Affiliation -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_no_affiliation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <include layout="@layout/item_category_header"
                    android:id="@+id/no_affiliation_header"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>